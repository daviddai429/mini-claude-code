#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BUN="$HOME/.bun/bin/bun"
BUN_ARGS=(--preload "$ROOT_DIR/preload.ts" --env-file="$ROOT_DIR/.env")

# Force recovery CLI (simple readline REPL, no Ink TUI)
if [[ "${CLAUDE_CODE_FORCE_RECOVERY_CLI:-0}" == "1" ]]; then
  exec "$BUN" "${BUN_ARGS[@]}" "$ROOT_DIR/src/localRecoveryCli.ts" "$@"
fi

# On MinTTY (Git Bash for Windows), use winpty for proper TTY support
if [[ "${TERM_PROGRAM:-}" == "mintty" ]] && command -v winpty &>/dev/null; then
  exec winpty "$BUN" "${BUN_ARGS[@]}" "$ROOT_DIR/src/entrypoints/cli.tsx" "$@"
fi

# Default: full CLI with Ink TUI
exec "$BUN" "${BUN_ARGS[@]}" "$ROOT_DIR/src/entrypoints/cli.tsx" "$@"
